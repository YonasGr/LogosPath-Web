---
import Layout from '../layouts/Layout.astro';

const releaseUrl = 'https://github.com/yonasgr/logospath/releases';

const metrics = [
	{ value: 'AI', label: 'Devotionals, growth insights, and theology chat' },
	{ value: '4 tabs', label: 'Overview, historical context, original meaning, modern application' },
	{ value: 'Firebase', label: 'Auth, persistence, streaks, and notifications' },
];

const features = [
	{
		title: 'AI-powered devotionals',
		text: 'Themed daily readings with historical context, original Hebrew and Greek meaning, and modern application.',
	},
	{
		title: 'Live theological chat',
		text: 'A Claude-powered Q&A experience for grounded study, follow-up questions, and richer understanding.',
	},
	{
		title: 'Growth tracking',
		text: 'Streaks, points, achievements, quizzes, and personal analytics that keep momentum visible.',
	},
	{
		title: 'Firebase-backed account flow',
		text: 'Email/password and Google sign-in, with Firestore history for devotionals, chat, and progress.',
	},
	{
		title: 'Android-first release',
		text: 'Users can install the APK directly from GitHub Releases until the Play Store launch is ready.',
	},
	{
		title: 'Premium motion',
		text: 'Clean transitions, layered mobile framing, and subtle depth that stays focused on the content.',
	},
];

const steps = [
	'Open the latest GitHub Release from the button below.',
	'Download the APK straight to your Android device.',
	'Install, sign in, and start your next study session.',
];
---

<Layout
	title="Logos Path — Premium Bible study and spiritual growth on Android"
	description="Download the Logos Path APK from GitHub Releases and explore AI devotionals, theological chat, quizzes, streaks, and growth insights."
>
	<main class="page">
		<div class="ambient ambient-one"></div>
		<div class="ambient ambient-two"></div>

		<section class="hero">
			<div class="hero-copy">
				<div class="brand-row">
					<img src="/logospath/icon.png" alt="Logos Path app icon" class="brand-icon" />
					<div>
						<p class="eyebrow">Android app · GitHub Releases APK</p>
						<h2>Logos Path</h2>
					</div>
				</div>

				<p class="pill">Built for Bible study, reflection, and spiritual growth</p>
				<h1>Walk in the Word with a calm, premium mobile experience.</h1>
				<p class="lede">
					Logos Path brings AI devotionals, live theology chat, quizzes, growth insights, and personal streaks
					into a warm, distraction-free Android app.
				</p>

				<div class="actions">
					<a class="button button-primary" href={releaseUrl} target="_blank" rel="noreferrer">
						Download release APK
					</a>
					<a class="button button-secondary" href="#features">Explore features</a>
				</div>

				<dl class="metrics">
					{metrics.map((item) => (
						<div class="metric">
							<dt>{item.value}</dt>
							<dd>{item.label}</dd>
						</div>
					))}
				</dl>
			</div>

			<div class="hero-visual" aria-label="Logos Path app preview">
				<div class="device device-back">
					<div class="device-shell">
						<div class="device-notch"></div>
						<img src="/logospath/ob-study.png" alt="" class="screen image-cover" />
					</div>
				</div>

				<div class="device device-front">
					<div class="device-shell">
						<div class="device-status">
							<span>9:41</span>
							<span>5G</span>
						</div>
						<div class="device-notch"></div>
						<div class="screen screen-compose">
							<img src="/logospath/share-card-template.png" alt="" class="compose-card" />
							<div class="screen-copy">
								<p class="screen-label">Today’s devotional</p>
								<h3>Historical context, original meaning, modern application.</h3>
								<p>
									Each session turns into a focused reading experience with prayer, reflection, and progress
									tracking.
								</p>
							</div>
						</div>
					</div>
				</div>

				<div class="device device-float">
					<div class="device-shell">
						<div class="device-notch"></div>
						<img src="/logospath/ob-journey.png" alt="" class="screen image-cover" />
					</div>
				</div>

				<div class="badge-card badge-top">
					<p>Claude Sonnet 4</p>
					<span>Grounded theological Q&A</span>
				</div>
				<div class="badge-card badge-bottom">
					<p>Firebase-backed</p>
					<span>Auth, history, and streaks</span>
				</div>
			</div>
		</section>

		<section class="trust-strip">
			<p>Expo · React Native · Firebase · Reanimated · DM Sans · Crimson Pro</p>
		</section>

		<section class="section" id="features">
			<div class="section-heading">
				<p class="section-kicker">What users get</p>
				<h2>Everything needed for a clean daily study rhythm.</h2>
			</div>

			<div class="feature-grid">
				{features.map((feature) => (
					<article class="feature-card">
						<h3>{feature.title}</h3>
						<p>{feature.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="section section-split">
			<div class="panel panel-dark">
				<p class="section-kicker">APK delivery</p>
				<h2>Users can install the app directly from the website.</h2>
				<p>
					The Play Store listing can come later. For now, the release button takes visitors straight to the
					GitHub Releases page so they can download the latest Android build.
				</p>
				<div class="button-row">
					<a class="button button-primary" href={releaseUrl} target="_blank" rel="noreferrer">
						Get the latest APK
					</a>
				</div>
			</div>

			<div class="panel">
				<p class="section-kicker">How it feels</p>
				<h2>A premium rhythm without clutter.</h2>
				<div class="step-list">
					{steps.map((step, index) => (
						<div class="step">
							<span>{index + 1}</span>
							<p>{step}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.page {
		position: relative;
		overflow: clip;
		padding: 32px 24px 40px;
	}

	.ambient {
		position: absolute;
		inset: auto;
		width: 34rem;
		height: 34rem;
		border-radius: 999px;
		filter: blur(70px);
		opacity: 0.35;
		pointer-events: none;
		z-index: 0;
	}

	.ambient-one {
		top: -10rem;
		right: -9rem;
		background: rgba(230, 0, 35, 0.16);
	}

	.ambient-two {
		left: -12rem;
		top: 20rem;
		background: rgba(201, 168, 76, 0.11);
	}

	.hero,
	.section,
	.trust-strip {
		position: relative;
		z-index: 1;
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
		gap: 40px;
		align-items: center;
		min-height: min(92vh, 940px);
		padding: 24px 0 40px;
	}

	.brand-row {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 18px;
	}

	.brand-icon {
		width: 64px;
		height: 64px;
		border-radius: 20px;
		box-shadow: 0 18px 35px rgba(38, 38, 34, 0.14);
	}

	.brand-row h2 {
		margin: 2px 0 0;
		font: 700 1.35rem/1 var(--font-sans);
		letter-spacing: -0.03em;
		color: var(--text-strong);
	}

	.eyebrow,
	.section-kicker,
	.pill,
	.screen-label,
	.metric dt,
	.badge-card p,
	.device-status,
	.trust-strip p {
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	.eyebrow,
	.section-kicker,
	.pill,
	.screen-label,
	.device-status,
	.trust-strip p {
		font-size: 0.72rem;
	}

	.eyebrow {
		margin: 0;
		color: var(--brand);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 8px 12px;
		margin: 0 0 22px;
		border-radius: 999px;
		background: var(--surface-2);
		border: 1px solid var(--border);
		color: var(--muted);
	}

	h1,
	.section-heading h2,
	.panel h2 {
		margin: 0;
		color: var(--text-strong);
		letter-spacing: -0.05em;
		line-height: 0.94;
		font-family: var(--font-display);
	}

	h1 {
		font-size: clamp(3.4rem, 8vw, 6.1rem);
		max-width: 10ch;
	}

	.lede {
		max-width: 58ch;
		margin: 24px 0 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--muted);
	}

	.actions,
	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 18px;
		border-radius: 999px;
		border: 1px solid transparent;
		font: 700 0.95rem/1 var(--font-sans);
		letter-spacing: -0.01em;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: var(--brand);
		color: #fff;
		box-shadow: 0 18px 35px rgba(230, 0, 35, 0.22);
	}

	.button-primary:hover {
		background: var(--brand-dark);
	}

	.button-secondary {
		background: var(--surface);
		border-color: var(--border);
		color: var(--text-strong);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin: 34px 0 0;
	}

	.metric {
		padding: 18px 16px;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(218, 218, 211, 0.9);
		box-shadow: 0 20px 40px rgba(38, 38, 34, 0.05);
	}

	.metric dt {
		margin-bottom: 10px;
		color: var(--brand);
		font-size: 0.7rem;
		font-weight: 700;
	}

	.metric dd {
		margin: 0;
		color: var(--text);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.hero-visual {
		position: relative;
		min-height: 760px;
		display: grid;
		place-items: center;
	}

	.device {
		position: absolute;
		width: 320px;
		border-radius: 42px;
		padding: 12px;
		background: linear-gradient(180deg, #11110f 0%, #2e2e29 100%);
		box-shadow: 0 45px 120px rgba(38, 38, 34, 0.22);
		animation: float 7s ease-in-out infinite;
	}

	.device-shell {
		position: relative;
		overflow: hidden;
		border-radius: 34px;
		background: var(--surface);
		border: 1px solid rgba(255, 255, 255, 0.26);
	}

	.device-notch {
		position: absolute;
		top: 10px;
		left: 50%;
		width: 110px;
		height: 28px;
		transform: translateX(-50%);
		border-radius: 999px;
		background: rgba(38, 38, 34, 0.94);
		z-index: 2;
	}

	.screen {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.image-cover {
		aspect-ratio: 9 / 16;
	}

	.screen-compose {
		aspect-ratio: 9 / 16;
		padding: 58px 20px 20px;
		background:
			radial-gradient(circle at top, rgba(230, 0, 35, 0.08), transparent 34%),
			var(--surface);
	}

	.compose-card {
		width: 100%;
		aspect-ratio: 1672 / 941;
		border-radius: 26px;
		object-fit: cover;
		box-shadow: 0 18px 40px rgba(38, 38, 34, 0.12);
	}

	.device-status {
		position: absolute;
		top: 14px;
		left: 24px;
		right: 24px;
		display: flex;
		justify-content: space-between;
		z-index: 2;
		color: var(--muted);
		font-size: 0.62rem;
	}

	.screen-copy {
		padding: 18px 8px 0;
	}

	.screen-copy h3,
	.feature-card h3 {
		margin: 0;
		color: var(--text-strong);
		font: 700 1.15rem/1.25 var(--font-sans);
		letter-spacing: -0.04em;
	}

	.screen-copy p,
	.feature-card p,
	.panel p,
	.step p {
		margin: 0;
		color: var(--muted);
		line-height: 1.65;
		font-size: 0.98rem;
	}

	.screen-copy p {
		margin-top: 10px;
	}

	.device-back {
		top: 38px;
		left: 2%;
		width: 262px;
		transform: rotate(-12deg);
		animation-delay: -1.4s;
	}

	.device-front {
		z-index: 2;
		width: 340px;
		transform: translateX(14px) translateY(18px);
		animation-delay: -2.6s;
	}

	.device-float {
		right: 2%;
		bottom: 52px;
		width: 238px;
		transform: rotate(10deg);
		animation-delay: -4s;
	}

	.badge-card {
		position: absolute;
		padding: 14px 16px;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.82);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(218, 218, 211, 0.9);
		box-shadow: 0 18px 40px rgba(38, 38, 34, 0.09);
		animation: float 8s ease-in-out infinite;
	}

	.badge-card p {
		margin: 0 0 6px;
		color: var(--brand);
		font-size: 0.65rem;
		font-weight: 700;
	}

	.badge-card span {
		display: block;
		font-size: 0.9rem;
		color: var(--text);
		line-height: 1.4;
		max-width: 18ch;
	}

	.badge-top {
		top: 66px;
		right: 12px;
	}

	.badge-bottom {
		left: 0;
		bottom: 84px;
		animation-delay: -2s;
	}

	.trust-strip {
		padding: 16px 0 0;
	}

	.trust-strip p {
		margin: 0;
		padding: 14px 18px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid var(--border);
		color: var(--muted);
		text-align: center;
	}

	.section {
		padding-top: 92px;
	}

	.section-heading {
		max-width: 700px;
		margin-bottom: 28px;
	}

	.section-heading h2,
	.panel h2 {
		font-size: clamp(2.2rem, 4vw, 3.4rem);
		max-width: 13ch;
		line-height: 0.98;
	}

	.section-kicker {
		margin: 0 0 12px;
		color: var(--brand);
		font-weight: 700;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.feature-card,
	.panel {
		padding: 24px;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(18px);
		border: 1px solid rgba(218, 218, 211, 0.95);
		box-shadow: 0 20px 45px rgba(38, 38, 34, 0.05);
	}

	.feature-card h3 {
		margin-bottom: 12px;
	}

	.feature-card p {
		font-size: 0.96rem;
	}

	.section-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.panel-dark {
		background: linear-gradient(180deg, #262622 0%, #33332e 100%);
		color: #fff;
		border-color: rgba(255, 255, 255, 0.08);
	}

	.panel-dark .section-kicker,
	.panel-dark h2,
	.panel-dark p {
		color: #fff;
	}

	.panel-dark .section-kicker {
		opacity: 0.8;
	}

	.step-list {
		display: grid;
		gap: 14px;
		margin-top: 18px;
	}

	.step {
		display: grid;
		grid-template-columns: 36px 1fr;
		gap: 14px;
		align-items: start;
		padding: 14px 0;
		border-top: 1px solid var(--border);
	}

	.step:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.step span {
		display: grid;
		place-items: center;
		width: 36px;
		height: 36px;
		border-radius: 999px;
		background: var(--surface-2);
		color: var(--text-strong);
		font: 700 0.9rem/1 var(--font-sans);
	}

	@keyframes float {
		0%,
		100% {
			transform: translate3d(0, 0, 0);
		}
		50% {
			transform: translate3d(0, -10px, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.device,
		.badge-card {
			animation: none;
		}

		.button {
			transition: none;
		}
	}

	@media (max-width: 1060px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-top: 0;
		}

		.hero-visual {
			min-height: 700px;
			order: -1;
			margin-bottom: 12px;
		}

		.feature-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.section-split {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-inline: 16px;
		}

		.hero-visual {
			min-height: 620px;
			transform: scale(0.84);
			transform-origin: top center;
			margin: -20px 0 -10px;
		}

		.metrics,
		.feature-grid {
			grid-template-columns: 1fr;
		}

		.device-front {
			transform: translateX(0) translateY(18px);
		}

		.badge-top {
			right: -6px;
		}

		.badge-bottom {
			left: -4px;
		}
	}
</style>
