---
import Layout from '../layouts/Layout.astro';

const releaseAssetUrl = 'https://github.com/yonasgr/logospath/releases/download/v1.0.0/LogosPath-v1.0.0.apk';

const metrics = [
	{ value: 'Guided', label: 'Devotionals, reflection, and study support' },
	{ value: 'Focused', label: 'Clean reading paths that keep attention on the Word' },
	{ value: 'Progress', label: 'Streaks, saved history, and ongoing momentum' },
];

const features = [
	{
		title: 'Guided devotionals',
		text: 'Themed daily readings designed to make study feel calm, clear, and consistent.',
	},
	{
		title: 'Study support',
		text: 'A conversational space for questions, follow-ups, and deeper understanding.',
	},
	{
		title: 'Progress tracking',
		text: 'Streaks, achievements, and visible momentum that keep the rhythm alive.',
	},
	{
		title: 'Personalized experience',
		text: 'A smooth account flow that keeps your study journey in one place.',
	},
	{
		title: 'Android-first release',
		text: 'Users can download the APK straight from the site.',
	},
	{
		title: 'Premium motion',
		text: 'Clean transitions, layered mobile framing, and subtle depth that stays focused on the content.',
	},
];

const steps = [
	'Tap the download button.',
	'Download the APK straight to your Android device.',
	'Install and start your next study session.',
];
---

<Layout
	title="Logos Path — Premium Bible study and spiritual growth on Android"
	description="Download the Logos Path APK and explore guided devotionals, study support, reflection tools, and progress tracking."
>
	<main class="page">
		<div class="ambient ambient-one"></div>
		<div class="ambient ambient-two"></div>

		<section class="hero">
			<div class="hero-copy">
				<div class="brand-row">
					<img src="/logospath/icon.png" alt="Logos Path app icon" class="brand-icon" />
					<div>
						<p class="eyebrow">Android app · Built for daily study</p>
						<h2>Logos Path</h2>
					</div>
				</div>

				<p class="pill">Built for Bible study, reflection, and spiritual growth</p>
				<h1>Walk in the Word with a calm, premium mobile experience.</h1>
				<p class="lede">
					Logos Path brings guided devotionals, study support, reflection tools, and progress tracking into a
					warm, distraction-free Android app.
				</p>

				<div class="actions">
					<a class="button button-primary" href={releaseAssetUrl} download="LogosPath-v1.0.0.apk">
						Download APK
					</a>
					<a class="button button-secondary" href="#features">Explore features</a>
				</div>

				<dl class="metrics">
					{metrics.map((item) => (
						<div class="metric">
							<dt>{item.value}</dt>
							<dd>{item.label}</dd>
						</div>
					))}
				</dl>
			</div>

			<div class="hero-visual" aria-label="Logos Path app preview">
				<img src="/logospath/home-screen-mock.png" alt="Logos Path home screen mockup" class="mock-image mock-home" />
				<img
					src="/logospath/analytic-screen-mock.png"
					alt="Logos Path analytics screen mockup"
					class="mock-image mock-analytics"
				/>
			</div>
		</section>

		<section class="trust-strip">
			<p>Daily devotionals · Reflection tools · Progress tracking · Android first</p>
		</section>

		<section class="section" id="features">
			<div class="section-heading">
				<p class="section-kicker">What users get</p>
				<h2>Everything needed for a clean daily study rhythm.</h2>
			</div>

			<div class="feature-grid">
				{features.map((feature) => (
					<article class="feature-card">
						<h3>{feature.title}</h3>
						<p>{feature.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="section">
			<div class="panel panel-wide">
				<p class="section-kicker">How it feels</p>
				<h2>A premium rhythm without clutter.</h2>
				<div class="step-list">
					{steps.map((step, index) => (
						<div class="step">
							<span>{index + 1}</span>
							<p>{step}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.page {
		position: relative;
		overflow: clip;
		padding: 32px 24px 40px;
	}

	.ambient {
		position: absolute;
		inset: auto;
		width: 34rem;
		height: 34rem;
		border-radius: 999px;
		filter: blur(70px);
		opacity: 0.35;
		pointer-events: none;
		z-index: 0;
	}

	.ambient-one {
		top: -10rem;
		right: -9rem;
		background: rgba(230, 0, 35, 0.16);
	}

	.ambient-two {
		left: -12rem;
		top: 20rem;
		background: rgba(201, 168, 76, 0.11);
	}

	.hero,
	.section,
	.trust-strip {
		position: relative;
		z-index: 1;
		max-width: 1180px;
		margin: 0 auto;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
		gap: 40px;
		align-items: center;
		min-height: min(92vh, 940px);
		padding: 24px 0 40px;
	}

	.brand-row {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 18px;
	}

	.brand-icon {
		width: 64px;
		height: 64px;
		border-radius: 20px;
		box-shadow: 0 18px 35px rgba(38, 38, 34, 0.14);
	}

	.brand-row h2 {
		margin: 2px 0 0;
		font: 700 1.35rem/1 var(--font-sans);
		letter-spacing: -0.03em;
		color: var(--text-strong);
	}

	.eyebrow,
	.section-kicker,
	.pill,
	.metric dt,
	.badge-card p,
	.trust-strip p {
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	.eyebrow,
	.section-kicker,
	.pill,
	.trust-strip p {
		font-size: 0.72rem;
	}

	.eyebrow {
		margin: 0;
		color: var(--brand);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 8px 12px;
		margin: 0 0 22px;
		border-radius: 999px;
		background: var(--surface-2);
		border: 1px solid var(--border);
		color: var(--muted);
	}

	h1,
	.section-heading h2,
	.panel h2 {
		margin: 0;
		color: var(--text-strong);
		letter-spacing: -0.05em;
		line-height: 0.94;
		font-family: var(--font-display);
	}

	h1 {
		font-size: clamp(3.4rem, 8vw, 6.1rem);
		max-width: 10ch;
	}

	.lede {
		max-width: 58ch;
		margin: 24px 0 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--muted);
	}

	.actions,
	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 18px;
		border-radius: 999px;
		border: 1px solid transparent;
		font: 700 0.95rem/1 var(--font-sans);
		letter-spacing: -0.01em;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: var(--brand);
		color: #fff;
		box-shadow: 0 18px 35px rgba(230, 0, 35, 0.22);
	}

	.button-primary:hover {
		background: var(--brand-dark);
	}

	.button-secondary {
		background: var(--surface);
		border-color: var(--border);
		color: var(--text-strong);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin: 34px 0 0;
	}

	.metric {
		padding: 18px 16px;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(218, 218, 211, 0.9);
		box-shadow: 0 20px 40px rgba(38, 38, 34, 0.05);
	}

	.metric dt {
		margin-bottom: 10px;
		color: var(--brand);
		font-size: 0.7rem;
		font-weight: 700;
	}

	.metric dd {
		margin: 0;
		color: var(--text);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.hero-visual {
		position: relative;
		min-height: 720px;
		display: grid;
		place-items: center;
	}

	.mock-image {
		position: absolute;
		width: min(100%, 420px);
		height: auto;
		filter:
			drop-shadow(0 24px 42px rgba(38, 38, 34, 0.12))
			drop-shadow(0 0 0.45rem rgba(38, 38, 34, 0.06));
		animation: float 7s ease-in-out infinite;
	}

	.mock-image::selection {
		background: transparent;
	}

	.mock-home {
		left: 0;
		top: 28px;
		width: 58%;
		transform: rotate(-7deg);
	}

	.mock-analytics {
		right: 0;
		bottom: 18px;
		width: 56%;
		transform: rotate(8deg);
		animation-delay: -2.2s;
	}

	.feature-card h3 {
		margin: 0;
		color: var(--text-strong);
		font: 700 1.15rem/1.25 var(--font-sans);
		letter-spacing: -0.04em;
	}

	.feature-card p,
	.panel p,
	.step p {
		margin: 0;
		color: var(--muted);
		line-height: 1.65;
		font-size: 0.98rem;
	}

	.trust-strip {
		padding: 16px 0 0;
	}

	.trust-strip p {
		margin: 0;
		padding: 14px 18px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid var(--border);
		color: var(--muted);
		text-align: center;
	}

	.section {
		padding-top: 92px;
	}

	.section-heading {
		max-width: 700px;
		margin-bottom: 28px;
	}

	.section-heading h2,
	.panel h2 {
		font-size: clamp(2.2rem, 4vw, 3.4rem);
		max-width: 13ch;
		line-height: 0.98;
	}

	.section-kicker {
		margin: 0 0 12px;
		color: var(--brand);
		font-weight: 700;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.feature-card,
	.panel {
		padding: 24px;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(18px);
		border: 1px solid rgba(218, 218, 211, 0.95);
		box-shadow: 0 20px 45px rgba(38, 38, 34, 0.05);
	}

	.feature-card h3 {
		margin-bottom: 12px;
	}

	.feature-card p {
		font-size: 0.96rem;
	}

	.panel-wide {
		max-width: 780px;
		margin: 0 auto;
	}

	.step-list {
		display: grid;
		gap: 14px;
		margin-top: 18px;
	}

	.step {
		display: grid;
		grid-template-columns: 36px 1fr;
		gap: 14px;
		align-items: start;
		padding: 14px 0;
		border-top: 1px solid var(--border);
	}

	.step:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.step span {
		display: grid;
		place-items: center;
		width: 36px;
		height: 36px;
		border-radius: 999px;
		background: var(--surface-2);
		color: var(--text-strong);
		font: 700 0.9rem/1 var(--font-sans);
	}

	@keyframes float {
		0%,
		100% {
			transform: translate3d(0, 0, 0);
		}
		50% {
			transform: translate3d(0, -10px, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.mock-image {
			animation: none;
		}

		.button {
			transition: none;
		}
	}

	@media (max-width: 1060px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-top: 0;
		}

		.hero-visual {
			min-height: 700px;
			order: -1;
			margin-bottom: 12px;
		}

		.feature-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

	}

	@media (max-width: 720px) {
		.page {
			padding-inline: 16px;
		}

		.hero-visual {
			min-height: 560px;
		}

		.metrics,
		.feature-grid {
			grid-template-columns: 1fr;
		}

		.mock-home {
			width: 64%;
		}

		.mock-analytics {
			width: 60%;
		}
	}
</style>
