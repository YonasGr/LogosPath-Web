---
const {
	title = 'Logos Path',
	description = 'Logos Path landing page',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#fbfbf9" />
		<meta name="color-scheme" content="light" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/png" href="/logospath/icon.png" />
		<link rel="apple-touch-icon" href="/logospath/icon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #fbfbf9;
		--surface: #ffffff;
		--surface-2: #f6f6f3;
		--border: #dadad3;
		--text: #33332e;
		--text-strong: #262622;
		--muted: #62625b;
		--brand: #e60023;
		--brand-dark: #cc001f;
		--shadow: rgba(38, 38, 34, 0.08);
		--font-sans: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		--font-display: 'Crimson Pro', Georgia, serif;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		background:
			radial-gradient(circle at top, rgba(230, 0, 35, 0.05), transparent 38%),
			var(--bg);
		color: var(--text);
		font-family: var(--font-sans);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	::selection {
		background: rgba(230, 0, 35, 0.18);
		color: var(--text-strong);
	}
</style>
